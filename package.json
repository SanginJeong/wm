{
  "name": "wondermall",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter=@wondermall/web dev",
    "build": "pnpm --recursive build",
    "preview": "pnpm --filter=@wondermall/web preview",
    "test": "pnpm --filter=@wondermall/web test",
    "test:ui": "pnpm --filter=@wondermall/web test:ui",
    "test:headed": "pnpm --filter=@wondermall/web test:headed",
    "test:report": "pnpm --filter=@wondermall/web test:report",
    "lint": "pnpm --filter=@wondermall/web lint",
    "lint:fix": "pnpm --filter=@wondermall/web lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm --recursive typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
